# GrantGenie environment template
# Copy to .env and fill in the values.

# ---- Laravel ----
APP_NAME=GrantGenie
APP_ENV=local
APP_KEY=                          # generate via: cd backend && php artisan key:generate --show
APP_URL=http://localhost:8000
APP_DEBUG=true

# ---- Database ----
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=grantgenie
DB_USERNAME=grantgenie
DB_PASSWORD=grantgenie

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ---- Queue / Cache ----
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# ---- OIDC (Auth0 or compatible) ----
OIDC_ISSUER=https://your-tenant.auth0.com/
OIDC_AUDIENCE=grantgenie-api
OIDC_CLIENT_ID=grantgenie-web
OIDC_CLIENT_SECRET=

# ---- Mail (MailHog in dev) ----
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@grantgenie.example"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Object storage (MinIO in dev, Azure Blob in prod) ----
OBJECT_STORAGE_DRIVER=s3
OBJECT_STORAGE_BUCKET=grantgenie-boilerplate
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_KEY=grantgenie
OBJECT_STORAGE_SECRET=grantgenie-secret
OBJECT_STORAGE_REGION=us-east-1

# ---- AI service ----
AI_SERVICE_URL=http://ai-service:8001
AI_SERVICE_INTERNAL_TOKEN=dev-internal-token  # shared secret for service-to-service; use mTLS in prod

# ---- Model providers ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=grantgenie
